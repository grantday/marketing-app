# Copy to .env.production on your server and fill in values.
# Generate secrets: bash deploy/scripts/generate-secrets.sh

NODE_ENV=production

# --- Required ---
# Managed PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@db-host:5432/reach?sslmode=require"

REDIS_URL="redis://redis:6379"

# Public URL of the web app (HTTPS in production)
CLIENT_ORIGIN="https://reach.yourdomain.com"

# Must match CLIENT_ORIGIN host for cookies behind nginx
# Used for short links in messages
LINK_BASE_URL="https://reach.yourdomain.com"

PORT=3002
HOST=0.0.0.0
TRUST_PROXY=true

# Generate with deploy/scripts/generate-secrets.sh
JWT_SECRET=""
TOKEN_ENCRYPTION_KEY=""

# --- Meta WhatsApp (required for messaging) ---
META_APP_SECRET=""
META_WEBHOOK_VERIFY_TOKEN=""
# Optional defaults if not using in-app setup:
# META_ACCESS_TOKEN=""
# META_PHONE_NUMBER_ID=""
# META_WABA_ID=""
META_APP_ID=""
META_EMBEDDED_CONFIG_ID=""

# --- Email (signup verification) ---
RESEND_API_KEY=""
EMAIL_FROM="Reach <noreply@yourdomain.com>"

# --- Stripe (optional) ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_GROWTH=""
STRIPE_PRICE_ENTERPRISE=""

# --- OpenAI (optional) ---
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# --- CRM bridge (optional) ---
ARENARAMA_API_URL=""
ARENARAMA_API_COOKIE=""

# Docker compose port mapping
HTTP_PORT=80

# Self-hosted postgres only (if using compose postgres service)
# POSTGRES_USER=reach
# POSTGRES_PASSWORD=
# POSTGRES_DB=reach
